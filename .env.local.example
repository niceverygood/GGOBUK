# AI
# OpenRouter is preferred when set. Anthropic is kept as a fallback.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL_MAIN=anthropic/claude-opus-4.7
OPENROUTER_MODEL_SAJU=openai/gpt-5.1
OPENROUTER_MODEL_COMPAT=openai/gpt-5.1
OPENROUTER_MODEL_CHEAP=anthropic/claude-haiku-4.5
OPENROUTER_APP_NAME=GGOBUK
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI image generation
# Server-only. Used for "부적 받기" image generation.
OPENAI_API_KEY=sk-proj-...
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_FORMAT=png

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# New name (Supabase 2025+). Older projects may still use NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=

# Kakao
KAKAO_REST_API_KEY=
KAKAO_ADMIN_KEY=
# Credit purchases use Kakao Pay one-time payments.
KAKAO_PAY_CID=TC0ONETIME
# Optional override when production one-time CID differs from legacy CID.
KAKAO_PAY_CID_ONETIME=
KAKAO_PAY_SECRET_KEY=

# FCM
FCM_SERVER_KEY=
NEXT_PUBLIC_FCM_VAPID_KEY=

# App
# Local development: http://localhost:3000
# Vercel production: https://ggobuk.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# Optional
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
